# ============ REQUIRED ============
DATABASE_URL=postgresql://crawlseo:changeme@localhost:5432/crawlseo
APP_SECRET=change-me-to-random-string
# Generate with: openssl rand -hex 32

# ============ DOCKER COMPOSE DB CREDENTIALS ============
# These are referenced by docker-compose.yml — set your own for non-local deployments.
POSTGRES_USER=crawlseo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=crawlseo

# ============ GOOGLE OAUTH (required for GSC data) ============
# Get these from: https://console.cloud.google.com/
# Required scopes: openid, email, profile, https://www.googleapis.com/auth/webmasters.readonly
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Optional: PageSpeed Insights API key (higher quota for Core Web Vitals)
# GOOGLE_PAGESPEED_KEY=

# ============ NEXTAUTH / AUTH.JS ============
# Production (Vercel): set to https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
# AUTH_SECRET works as alias for Auth.js v5
# AUTH_SECRET=

# ============ OPTIONAL: Scheduling ============
# Cron format: "minute hour day-of-month month day-of-week"
# CRAWL_SCHEDULE=0 0 * * 0                    # Weekly Sunday midnight
# GSC_SYNC_SCHEDULE=0 2 * * *                 # Daily 2am UTC
# VITALS_SCHEDULE=0 3 * * 0                   # Weekly Sunday 3am UTC

# ============ OPTIONAL: Registration ============
# Set to true after creating your admin account to prevent new registrations
# DISABLE_REGISTRATION=false

# ============ OPTIONAL: Email Notifications ============
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=alerts@crawlseo.dev

# ============ OPTIONAL: Telegram Notifications ============
# Get from: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=your-bot-token-here

# ============ OPTIONAL: Slack Notifications ============
# Create at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============ OPTIONAL: Redis (for job queue, future) ============
# REDIS_URL=redis://localhost:6379

# ============ NODE ENVIRONMENT ============
# NODE_ENV=development
